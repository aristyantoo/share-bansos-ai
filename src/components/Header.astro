<script>
	// Translation Dictionary
	const translations: Record<string, Record<string, string>> = {
		id: {
			"nav.home": "Beranda",
			"nav.category": "Kategori",
			"nav.about": "Tentang",
			"hero.title": "⚡ Jelajahi Alat AI Terbaik ⚡",
			"hero.subtitle": "Koleksi terkurasi dari produk AI yang paling kuat, indah, dan canggih untuk meningkatkan alur kerja Anda.",
			"search.placeholder": "Cari Alat AI...",
			"search.noresults": "Tidak ada alat yang cocok dengan pencarian Anda 😔",
			"search.noresults_sub": "Coba cari kategori seperti \"LLM\", \"Coding\", atau pencipta tertentu.",
			"tools.featured": "Unggulan",
			"tools.creator": "Oleh",
			"tools.value_prefix": "Terbaik untuk",
			"tools.explore": "Jelajahi →",
			"detail.category": "Kategori",
			"detail.pricing": "Harga",
			"detail.highlight": "Sorotan Utama",
			"detail.visit": "Kunjungi Situs Web",
			"detail.related": "Alat Terkait",
		},
		en: {
			"nav.home": "Home",
			"nav.category": "Categories",
			"nav.about": "About",
			"hero.title": "⚡ Explore the Best AI Tools ⚡",
			"hero.subtitle": "A curated collection of the most powerful, beautiful, and advanced AI products to level up your workflow.",
			"search.placeholder": "Search AI Tools...",
			"search.noresults": "No tools match your search 😔",
			"search.noresults_sub": "Try searching for categories like \"LLM\", \"Coding\", or specific creators.",
			"tools.featured": "Featured",
			"tools.creator": "By",
			"tools.value_prefix": "Best for",
			"tools.explore": "Explore →",
			"detail.category": "Category",
			"detail.pricing": "Pricing",
			"detail.highlight": "Key Highlight",
			"detail.visit": "Visit Website",
			"detail.related": "Related Tools",
		}
	};

	// Apply Language function
	function applyLanguage(lang: string) {
		document.documentElement.lang = lang;
		localStorage.setItem('lang', lang);
		
		// Update UI Elements with data-i18n attribute
		document.querySelectorAll('[data-i18n]').forEach(el => {
			const key = el.getAttribute('data-i18n');
			if (!key) return;
			const trans = translations[lang]?.[key];
			if (trans) {
				if (el.tagName === 'INPUT') {
					(el as HTMLInputElement).placeholder = trans;
				} else {
					el.textContent = trans;
				}
			}
		});


		// Update switcher button active state
		document.querySelectorAll('.lang-btn').forEach(btn => {
			const btnLang = btn.getAttribute('data-lang');
			if (btnLang === lang) {
				btn.classList.add('active');
			} else {
				btn.classList.remove('active');
			}
		});
	}

	// Initial Language load (Default to Bahasa Indonesia 'id')
	const savedLang = localStorage.getItem('lang') || 'id';
	applyLanguage(savedLang);

	// Bind Events
	document.querySelectorAll('.lang-btn').forEach(btn => {
		btn.addEventListener('click', () => {
			const lang = btn.getAttribute('data-lang');
			if (lang) {
				applyLanguage(lang);
			}
		});
	});

	// Mobile menu toggle logic
	const mobileToggle = document.getElementById('mobile-toggle');
	const headerNav = document.getElementById('header-nav');

	if (mobileToggle && headerNav) {
		mobileToggle.addEventListener('click', (e) => {
			e.stopPropagation();
			const isExpanded = mobileToggle.getAttribute('aria-expanded') === 'true';
			mobileToggle.setAttribute('aria-expanded', !isExpanded ? 'true' : 'false');
			headerNav.classList.toggle('active');
		});

		// Close menu if clicking outside
		document.addEventListener('click', (e) => {
			const target = e.target as HTMLElement;
			if (!headerNav.contains(target) && !mobileToggle.contains(target)) {
				mobileToggle.setAttribute('aria-expanded', 'false');
				headerNav.classList.remove('active');
			}
		});
	}
</script>

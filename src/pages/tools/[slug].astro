---
import { type CollectionEntry, getCollection } from 'astro:content';
import { render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ToolLogo from '../../components/ToolLogo.astro';

export async function getStaticPaths() {
	const tools = await getCollection('tools');
	return tools.map((tool) => ({
		params: { slug: tool.id },
		props: { tool },
	}));
}
type Props = {
	tool: CollectionEntry<'tools'>;
};

const { tool } = Astro.props;
const { Content } = await render(tool);

const targetUrl = tool.data.affiliateUrl || tool.data.url;
const hasAffiliate = !!tool.data.affiliateUrl;

// Get related tools (same category, excluding current tool)
const isFreeOnly = tool.data.pricing && !tool.data.price.includes('/') && (tool.data.price.toLowerCase().includes('gratis') || tool.data.price.toLowerCase().includes('free'));

const allTools = await getCollection('tools');
const relatedTools = allTools
	.filter((t) => t.id !== tool.id && t.data.category === tool.data.category)
	.slice(0, 2);

// Helper to format price parts for bilingual display
function formatPricePart(part: string) {
	if (!part) return { id: '', en: '' };
	const trimmed = part.trim();
	if (trimmed === 'Free') {
		return { id: 'Gratis', en: 'Free' };
	}
	if (trimmed === 'Free Trial') {
		return { id: 'Uji Coba Gratis', en: 'Free Trial' };
	}
	if (trimmed.startsWith('From ')) {
		const clean = trimmed.replace('From ', '').replace('/mo', '');
		return { id: `Mulai ${clean}/bulan`, en: `From ${clean}/mo` };
	}
	const cleanId = trimmed.replace('/mo', '/bulan');
	return { id: cleanId, en: trimmed };
}
---

<!doctype html>
<html lang="id">
	<head>
		<BaseHead title={`${tool.data.name} - Share Bansos AI`} description={tool.data.description} />
		<style>
			/* ─── BREADCRUMB ─────────────────────────────── */
			.breadcrumb {
				font-size: 0.8rem;
				color: var(--color-accent);
				opacity: 0.6;
				display: flex;
				align-items: center;
				gap: 8px;
				padding-left: 12px;
				font-weight: 500;
			}
			.breadcrumb a {
				text-decoration: none;
				transition: opacity 0.15s;
			}
			.breadcrumb a:hover {
				opacity: 0.7;
			}
			.breadcrumb span {
				opacity: 0.5;
			}

			/* ─── LAYOUT ─────────────────────────────────── */
			.detail-container {
				display: grid;
				grid-template-columns: 2fr 1fr;
				gap: 40px;
				align-items: start;
				margin-top: 24px;
			}

			/* ─── MAIN COLUMN ────────────────────────────── */
			.main-column {
				display: flex;
				flex-direction: column;
				gap: 32px;
				min-width: 0;
			}

			/* HERO CARD */
			.hero-card {
				background: #ffffff;
				border: 2px solid var(--color-accent);
				border-radius: 24px;
				box-shadow: 6px 6px 0px var(--color-accent);
				padding: 32px;
				position: relative;
				overflow: hidden;
			}
			.hero-top {
				display: flex;
				align-items: flex-start;
				justify-content: space-between;
				gap: 20px;
				margin-bottom: 20px;
			}
			.hero-left {
				display: flex;
				flex-direction: column;
				align-items: flex-start;
				gap: 16px;
			}
			.hero-brand-row {
				display: flex;
				align-items: center;
				gap: 20px;
			}
			.tool-detail-logo {
				width: 72px;
				height: 72px;
				border-radius: 16px;
				border: 2px solid var(--color-accent);
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 2.2rem;
				font-weight: bold;
				background: #FAF2EA;
				box-shadow: 3px 3px 0px var(--color-accent);
			}
			.tool-detail-logo :global(svg) {
				width: 42px;
				height: 42px;
			}
			.tool-meta-title h1 {
				margin: 0;
				line-height: 1.1;
				font-size: 2.4rem;
				font-family: var(--font-body);
				font-weight: 800;
			}
			.tool-creator {
				margin: 5px 0 0 0;
				font-size: 0.95rem;
				font-weight: 600;
				opacity: 0.85;
			}
			.tool-creator a {
				text-decoration: underline;
			}
			
			.tool-badges {
				display: flex;
				flex-wrap: wrap;
				gap: 8px;
				margin-bottom: 12px;
			}
			.badge {
				display: inline-flex;
				align-items: center;
				gap: 4px;
				padding: 4px 10px;
				border-radius: 8px;
				border: 2px solid var(--color-accent);
				font-size: 0.75rem;
				font-weight: 800;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				box-shadow: 2px 2px 0px var(--color-accent);
			}
			.badge-category {
				background: #E0F2FE; /* Light blue */
			}
			.badge-featured {
				background: #FEF08A; /* Light yellow */
			}
			.badge-hot {
				background: #FED7AA; /* Light orange */
			}

			.hero-actions {
				display: flex;
				align-items: center;
				gap: 12px;
			}
			.btn-primary {
				display: inline-flex;
				align-items: center;
				gap: 8px;
				padding: 12px 24px;
				border-radius: 30px;
				background: #F38C3B;
				border: 2px solid var(--color-accent);
				font-weight: 800;
				font-size: 0.95rem;
				box-shadow: 3px 3px 0px var(--color-accent);
				transition: all 0.15s ease;
				cursor: pointer;
				white-space: nowrap;
			}
			.btn-primary:hover {
				transform: translate(-2px, -2px);
				box-shadow: 5px 5px 0px var(--color-accent);
			}
			.btn-bookmark {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 44px;
				height: 44px;
				border-radius: 50%;
				background: #ffffff;
				border: 2px solid var(--color-accent);
				box-shadow: 3px 3px 0px var(--color-accent);
				transition: all 0.15s ease;
				cursor: pointer;
			}
			.btn-bookmark:hover {
				transform: translate(-1px, -1px);
				box-shadow: 4px 4px 0px var(--color-accent);
				background: #FAF2EA;
			}
			.btn-bookmark svg {
				transition: fill 0.2s ease, stroke 0.2s ease, transform 0.2s ease;
			}
			.btn-bookmark:hover svg {
				fill: #FFC700;
				transform: scale(1.1);
			}
			.btn-bookmark.active svg {
				fill: #FFC700;
				stroke: var(--color-accent);
			}

			/* Tooltip */
			.tooltip-wrapper {
				position: relative;
				display: inline-flex;
			}
			.tooltip-content {
				position: absolute;
				top: calc(100% + 10px);
				right: 0;
				transform: translateY(4px);
				background: #ffffff;
				border: 2px solid var(--color-accent);
				padding: 6px 10px;
				border-radius: 8px;
				box-shadow: 2px 2px 0px var(--color-accent);
				color: var(--color-accent);
				font-size: 0.75rem;
				font-weight: 800;
				white-space: nowrap;
				pointer-events: none;
				opacity: 0;
				visibility: hidden;
				transition: opacity 0.15s ease, transform 0.15s ease, visibility 0.15s ease;
				z-index: 50;
			}
			.tooltip-content::after {
				content: '';
				position: absolute;
				bottom: 100%;
				right: 16px;
				border-width: 6px;
				border-style: solid;
				border-color: transparent transparent var(--color-accent) transparent;
			}
			.tooltip-content::before {
				content: '';
				position: absolute;
				bottom: calc(100% - 2px);
				right: 17px;
				border-width: 5px;
				border-style: solid;
				border-color: transparent transparent #ffffff transparent;
				z-index: 1;
			}
			.tooltip-wrapper:hover .tooltip-content {
				opacity: 1;
				visibility: visible;
				transform: translateY(0);
			}
			.btn-bookmark + .tooltip-content .tooltip-remove {
				display: none;
			}
			.btn-bookmark + .tooltip-content .tooltip-save {
				display: inline;
			}
			.btn-bookmark.active + .tooltip-content .tooltip-save {
				display: none;
			}
			.btn-bookmark.active + .tooltip-content .tooltip-remove {
				display: inline;
			}
			.tool-desc {
				font-size: 1.05rem;
				line-height: 1.6;
				margin: 0;
			}
			.hero-divider {
				border-top: 2px solid var(--color-accent);
				margin: 20px 0;
			}

			/* QUICK STATS */
			.quick-stats {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 16px;
			}
			.stat-card {
				background: #ffffff;
				border: 2px solid var(--color-accent);
				border-radius: 16px;
				box-shadow: 4px 4px 0px var(--color-accent);
				padding: 16px;
				display: flex;
				flex-direction: column;
				gap: 6px;
			}
			.stat-label {
				font-size: 0.75rem;
				font-weight: 800;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				opacity: 0.65;
			}
			.stat-value {
				font-size: 1.25rem;
				font-weight: 800;
				line-height: 1.2;
			}
			.stat-value.green {
				color: #10B981;
			}
			.stat-sub {
				font-size: 0.8rem;
				opacity: 0.7;
			}

			/* SECTIONS */
			.neo-section {
				background: #ffffff;
				border: 2px solid var(--color-accent);
				border-radius: 24px;
				box-shadow: 6px 6px 0px var(--color-accent);
				padding: 32px;
			}
			.section-title {
				font-family: var(--font-heading);
				font-size: 2.2rem;
				font-weight: bold;
				margin-bottom: 24px;
				display: flex;
				align-items: center;
				gap: 10px;
				line-height: 1;
			}
			.section-title-dot {
				width: 12px;
				height: 12px;
				background: #F38C3B;
				border: 2px solid var(--color-accent);
				border-radius: 50%;
			}

			/* FEATURES GRID */
			.features-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 16px;
			}
			.feature-item {
				background: #FAF2EA;
				border: 2px solid var(--color-accent);
				border-radius: 16px;
				box-shadow: 3px 3px 0px var(--color-accent);
				padding: 20px;
				transition: transform 0.15s ease;
			}
			.feature-item:hover {
				transform: translate(-1px, -1px);
				box-shadow: 4px 4px 0px var(--color-accent);
			}
			.feature-icon-box {
				width: 40px;
				height: 40px;
				border-radius: 10px;
				background: #ffffff;
				border: 2px solid var(--color-accent);
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 1.3rem;
				margin-bottom: 12px;
				box-shadow: 2px 2px 0px var(--color-accent);
			}
			.feature-name {
				font-size: 1.1rem;
				font-weight: 800;
				margin-bottom: 6px;
			}
			.feature-desc {
				font-size: 0.9rem;
				line-height: 1.5;
				opacity: 0.85;
				margin: 0;
			}

			/* Free Only Pricing Custom Styling */
			.free-pricing-card {
				background: #FFFDF5;
				border: 2px solid var(--color-accent);
				border-radius: 24px;
				padding: 32px;
				position: relative;
				box-shadow: 6px 6px 0px var(--color-accent);
				margin-top: 16px;
				display: flex;
				flex-direction: column;
				gap: 20px;
				overflow: hidden;
			}
			.free-badge {
				position: absolute;
				top: 16px;
				right: 16px;
				background: #10B981;
				color: #ffffff;
				font-size: 0.75rem;
				font-weight: 900;
				padding: 6px 16px;
				border-radius: 50px;
				border: 2px solid var(--color-accent);
				box-shadow: 2px 2px 0px var(--color-accent);
				letter-spacing: 0.05em;
			}
			.free-card-header {
				margin-top: 12px;
			}
			.free-price-box {
				display: flex;
				align-items: center;
				gap: 16px;
				background: #ffffff;
				border: 2px solid var(--color-accent);
				padding: 16px 24px;
				border-radius: 16px;
				box-shadow: 3px 3px 0px var(--color-accent);
				width: fit-content;
				margin: 0 auto 20px auto;
			}
			.free-price-meta {
				display: flex;
				flex-direction: column;
				justify-content: center;
			}
			.free-features-section {
				margin-bottom: 24px;
			}
			.features-title {
				font-size: 0.95rem;
				font-weight: 800;
				margin-bottom: 12px;
				color: var(--color-accent);
			}
			.free-features-grid {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 12px;
			}
			.free-cta-btn {
				max-width: 320px;
				margin: 0 auto;
			}
			
			@media (max-width: 768px) {
				.free-pricing-card {
					padding: 24px;
				}
				.free-badge {
					position: relative;
					top: 0;
					right: 0;
					width: fit-content;
					margin-bottom: 16px;
				}
				.free-features-grid {
					grid-template-columns: 1fr;
				}
				.free-price-box {
					width: 100%;
				}
				.free-cta-btn {
					max-width: 100%;
				}
			}

			/* PRICING */
			.pricing-switcher-wrapper {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 24px;
				flex-wrap: wrap;
				gap: 12px;
			}
			.pricing-tabs {
				display: inline-flex;
				gap: 4px;
				background: #FAF2EA;
				border: 2px solid var(--color-accent);
				border-radius: 50px;
				padding: 4px;
				box-shadow: 2px 2px 0px var(--color-accent);
			}
			.pricing-tab {
				padding: 8px 18px;
				border-radius: 20px;
				font-size: 0.85rem;
				font-weight: 800;
				cursor: pointer;
				transition: all 0.15s;
				display: flex;
				align-items: center;
				gap: 6px;
			}
			.pricing-tab.active {
				background: var(--color-accent);
				color: #ffffff;
			}
			.annual-save-badge {
				background: #10B981;
				color: #ffffff;
				padding: 2px 6px;
				border-radius: 6px;
				font-size: 0.65rem;
				font-weight: 800;
			}
			.pricing-note {
				font-size: 0.8rem;
				opacity: 0.7;
			}
			.affiliate-disclaimer {
				margin-top: 16px;
				padding: 12px 16px;
				background: #fffbeb;
				border: 2px solid var(--color-accent);
				border-radius: 12px;
				box-shadow: 4px 4px 0px var(--color-accent);
				font-size: 0.8rem;
				color: var(--color-accent);
				font-weight: 500;
				display: flex;
				gap: 10px;
				align-items: flex-start;
				line-height: 1.5;
			}
			.affiliate-disclaimer-icon {
				font-size: 1.1rem;
				flex-shrink: 0;
			}
			.affiliate-disclaimer-text {
				margin: 0;
			}
			
			/* Pricing Standard Grid */
			.pricing-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 16px;
			}
			.pricing-card {
				background: #ffffff;
				border: 2px solid var(--color-accent);
				border-radius: 20px;
				padding: 24px;
				position: relative;
				box-shadow: 4px 4px 0px var(--color-accent);
				display: flex;
				flex-direction: column;
				transition: transform 0.15s ease;
			}
			.pricing-card:hover {
				transform: translateY(-2px);
				box-shadow: 6px 6px 0px var(--color-accent);
			}
			.pricing-card.popular {
				background: #FFFDF5;
				border-color: var(--color-accent);
				box-shadow: 6px 6px 0px var(--color-accent);
			}
			.pricing-card.popular:hover {
				box-shadow: 8px 8px 0px var(--color-accent);
			}
			.popular-badge {
				position: absolute;
				top: -12px;
				left: 50%;
				transform: translateX(-50%) rotate(-2deg);
				background: #FACC15;
				border: 2px solid var(--color-accent);
				color: var(--color-accent);
				font-size: 0.65rem;
				font-weight: 800;
				padding: 4px 12px;
				border-radius: 8px;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				box-shadow: 2px 2px 0px var(--color-accent);
			}
			.plan-name {
				font-size: 1.25rem;
				font-weight: 800;
				margin-bottom: 4px;
			}
			.plan-tagline {
				font-size: 0.85rem;
				opacity: 0.75;
				margin-bottom: 16px;
				line-height: 1.4;
				min-height: 40px;
			}
			.plan-price {
				display: flex;
				align-items: baseline;
				gap: 4px;
				margin-bottom: 2px;
			}
			.price-amount {
				font-size: 2.2rem;
				font-weight: 800;
			}
			.price-period {
				font-size: 0.95rem;
				font-weight: 700;
				opacity: 0.7;
			}
			.price-annual-note {
				font-size: 0.75rem;
				font-weight: 600;
				opacity: 0.7;
				margin-bottom: 20px;
				min-height: 18px;
			}
			.plan-cta {
				display: block;
				text-decoration: none;
				color: inherit;
				box-sizing: border-box;
				width: 100%;
				padding: 10px 16px;
				border-radius: 12px;
				border: 2px solid var(--color-accent);
				font-weight: 800;
				font-size: 0.9rem;
				cursor: pointer;
				transition: all 0.15s;
				text-align: center;
				margin-bottom: 20px;
				box-shadow: 2px 2px 0px var(--color-accent);
			}
			.plan-cta.cta-outline {
				background: #ffffff;
			}
			.plan-cta.cta-outline:hover {
				background: #FAF2EA;
				transform: translate(-1px, -1px);
				box-shadow: 3px 3px 0px var(--color-accent);
			}
			.plan-cta.cta-accent {
				background: #F38C3B;
			}
			.plan-cta.cta-accent:hover {
				transform: translate(-1px, -1px);
				box-shadow: 3px 3px 0px var(--color-accent);
			}
			.plan-divider {
				border-top: 2px dotted var(--color-accent);
				margin-bottom: 20px;
			}
			.plan-features {
				display: flex;
				flex-direction: column;
				gap: 10px;
				flex-grow: 1;
			}
			.plan-feature {
				display: flex;
				align-items: flex-start;
				gap: 8px;
				font-size: 0.85rem;
				line-height: 1.4;
			}
			.plan-feature .check {
				color: #10B981;
				font-weight: 800;
			}
			.plan-feature .cross {
				color: #EF4444;
				font-weight: 800;
			}

			.pricing-pane {
				display: none;
			}
			.pricing-pane.active {
				display: block;
			}

			/* Pricing Neo-Brutalist Slider */
			.neo-slider-container {
				background: #FAF2EA;
				border: 2px solid var(--color-accent);
				border-radius: 20px;
				padding: 24px;
				box-shadow: 4px 4px 0px var(--color-accent);
				margin-bottom: 24px;
			}
			.neo-slider-wrapper {
				position: relative;
				margin: 20px 0 10px 0;
			}
			.neo-slider {
				-webkit-appearance: none;
				appearance: none;
				width: 100%;
				height: 12px;
				border-radius: 10px;
				background: #ffffff;
				border: 2px solid var(--color-accent);
				outline: none;
			}
			.neo-slider::-webkit-slider-thumb {
				-webkit-appearance: none;
				appearance: none;
				width: 28px;
				height: 28px;
				border-radius: 50%;
				background: #F38C3B;
				border: 2px solid var(--color-accent);
				cursor: pointer;
				box-shadow: 2px 2px 0px var(--color-accent);
				transition: transform 0.1s;
			}
			.neo-slider::-webkit-slider-thumb:hover {
				transform: scale(1.15);
			}
			.neo-slider-labels {
				display: flex;
				justify-content: space-between;
				padding: 0 10px;
				margin-top: 8px;
			}
			.neo-slider-label {
				font-size: 0.8rem;
				font-weight: 800;
				cursor: pointer;
				opacity: 0.6;
				transition: all 0.15s;
			}
			.neo-slider-label.active {
				opacity: 1;
				color: #F38C3B;
				transform: scale(1.1);
			}
			.slider-card-wrapper {
				display: flex;
				justify-content: center;
				margin-top: 16px;
			}
			.slider-card-wrapper .pricing-card {
				width: 100%;
				max-width: 450px;
				background: #ffffff;
			}

			/* HOW TO GET STARTED */
			.steps {
				display: flex;
				flex-direction: column;
				gap: 20px;
			}
			.step-card {
				position: relative;
				background: #ffffff;
				border: 2px solid var(--color-accent);
				border-radius: 16px;
				padding: 24px 24px 24px 36px;
				box-shadow: 4px 4px 0px var(--color-accent);
			}
			.step-num {
				position: absolute;
				top: 50%;
				left: -16px;
				transform: translateY(-50%);
				width: 32px;
				height: 32px;
				border-radius: 50%;
				background: #FACC15;
				border: 2px solid var(--color-accent);
				display: flex;
				align-items: center;
				justify-content: center;
				font-weight: 800;
				box-shadow: 2px 2px 0px var(--color-accent);
				font-size: 0.95rem;
			}
			.step-title {
				font-size: 1.1rem;
				font-weight: 800;
				margin-bottom: 6px;
			}
			.step-desc {
				font-size: 0.9rem;
				line-height: 1.5;
				margin: 0;
				opacity: 0.9;
			}
			.step-code {
				margin-top: 12px;
				background: #FAF2EA;
				border: 2px solid var(--color-accent);
				border-radius: 8px;
				padding: 10px 14px;
				font-family: monospace;
				font-size: 0.85rem;
				color: var(--color-accent);
				font-weight: bold;
				display: inline-block;
			}

			/* COMPARISON TABLE */
			.table-wrapper {
				overflow-x: auto;
				border: 2px solid var(--color-accent);
				border-radius: 16px;
				box-shadow: 4px 4px 0px var(--color-accent);
			}
			.comparisons-table {
				width: 100%;
				border-collapse: collapse;
				background: #ffffff;
				font-size: 0.9rem;
				text-align: left;
			}
			.comparisons-table th {
				background: #FAF2EA;
				border-bottom: 2px solid var(--color-accent);
				padding: 12px 16px;
				font-weight: 800;
				text-transform: uppercase;
				font-size: 0.75rem;
				letter-spacing: 0.05em;
			}
			.comparisons-table td {
				padding: 14px 16px;
				border-bottom: 2px dotted rgba(10, 37, 64, 0.1);
			}
			.comparisons-table tr:last-child td {
				border-bottom: none;
			}
			.comparisons-table tr.highlighted {
				background: #FEF08A; /* Light yellow highlighting */
			}
			.comparisons-table tr.highlighted td {
				font-weight: 700;
			}
			.check-icon {
				color: #10B981;
				font-weight: bold;
			}
			.cross-icon {
				color: #EF4444;
				font-weight: bold;
			}

			/* ─── SIDEBAR COLUMN ─────────────────────────── */
			.detail-sidebar {
				display: flex;
				flex-direction: column;
				gap: 32px;
			}
			.sidebar-card {
				background: #ffffff;
				border: 2px solid var(--color-accent);
				border-radius: 20px;
				padding: 24px;
				box-shadow: 6px 6px 0px var(--color-accent);
			}
			.sidebar-title {
				font-size: 0.75rem;
				font-weight: 800;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				opacity: 0.65;
				margin-bottom: 16px;
			}

			/* ─── PROMO COUPONS ──────────────────────────── */
			.coupon-item {
				background: #fafafa;
				border: 2px dashed var(--color-accent);
				border-radius: 12px;
				padding: 16px;
				margin-top: 12px;
				position: relative;
				transition: all 0.2s ease;
			}
			.coupon-item:hover {
				background: #fdfdfd;
				transform: translateY(-2px);
				box-shadow: 4px 4px 0px var(--color-accent);
			}
			.coupon-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-bottom: 8px;
			}
			.coupon-discount {
				font-size: 0.85rem;
				font-weight: 800;
				color: #F38C3B;
				background: rgba(243, 140, 59, 0.1);
				padding: 4px 10px;
				border-radius: 20px;
				border: 2px solid var(--color-accent);
			}
			.coupon-desc {
				font-size: 0.85rem;
				line-height: 1.4;
				color: var(--color-accent);
				opacity: 0.85;
				margin: 0 0 12px 0;
				font-weight: 500;
			}
			.coupon-code-container {
				display: flex;
				border: 2px solid var(--color-accent);
				border-radius: 8px;
				overflow: hidden;
				background: #ffffff;
				box-shadow: 2px 2px 0px var(--color-accent);
				transition: transform 0.1s, box-shadow 0.1s;
			}
			.coupon-code-container:hover {
				transform: translate(-1px, -1px);
				box-shadow: 3px 3px 0px var(--color-accent);
			}
			.coupon-code-container:active {
				transform: translate(1px, 1px);
				box-shadow: 1px 1px 0px var(--color-accent);
			}
			.coupon-code {
				flex: 1;
				padding: 8px 12px;
				font-family: var(--font-mono, monospace);
				font-size: 0.9rem;
				font-weight: 800;
				color: var(--color-accent);
				background: #f3f4f6;
				display: flex;
				align-items: center;
				letter-spacing: 0.05em;
			}
			.coupon-copy-btn {
				background: #ffffff;
				border: none;
				border-left: 2px solid var(--color-accent);
				padding: 8px 14px;
				cursor: pointer;
				font-family: var(--font-body);
				font-size: 0.8rem;
				font-weight: 700;
				color: var(--color-accent);
				display: flex;
				align-items: center;
				gap: 6px;
				transition: all 0.1s ease;
				position: relative;
			}
			.coupon-copy-btn:hover {
				background: #F38C3B;
				color: #ffffff;
			}
			.coupon-copy-btn:active {
				background: #e07b2c;
			}

			/* Tooltip Trigger & Info Button */
			.coupon-info-trigger-wrapper {
				position: relative;
				display: flex;
				align-items: center;
				justify-content: center;
			}
			.coupon-info-trigger {
				background: #f3f4f6;
				border: 2px solid var(--color-accent);
				border-radius: 50%;
				color: var(--color-accent);
				cursor: pointer;
				width: 22px;
				height: 22px;
				display: flex;
				align-items: center;
				justify-content: center;
				padding: 0;
				transition: all 0.15s ease;
			}
			.coupon-info-trigger:hover {
				background: var(--color-accent);
				color: #ffffff;
			}
			.coupon-info-trigger .info-icon {
				display: block;
				transition: transform 0.15s ease;
			}
			.coupon-info-trigger:hover .info-icon {
				transform: scale(1.1);
			}

			/* CSS Tooltip */
			.coupon-tooltip {
				position: absolute;
				bottom: calc(100% + 8px);
				right: 0;
				width: 240px;
				background: #ffffff;
				border: 2px solid var(--color-accent);
				border-radius: 12px;
				padding: 12px;
				box-shadow: 4px 4px 0px var(--color-accent);
				z-index: 100;
				opacity: 0;
				visibility: hidden;
				transition: all 0.15s cubic-bezier(0.175, 0.885, 0.32, 1.275);
				transform: translateY(5px);
			}
			.coupon-info-trigger-wrapper:hover .coupon-tooltip,
			.coupon-info-trigger-wrapper:focus-within .coupon-tooltip {
				opacity: 1;
				visibility: visible;
				transform: translateY(0);
			}
			/* Tooltip Arrow */
			.coupon-tooltip::after {
				content: '';
				position: absolute;
				top: 100%;
				right: 6px;
				border-width: 6px;
				border-style: solid;
				border-color: var(--color-accent) transparent transparent transparent;
			}
			.coupon-tooltip::before {
				content: '';
				position: absolute;
				top: 100%;
				right: 7px;
				border-width: 5px;
				border-style: solid;
				border-color: #ffffff transparent transparent transparent;
				z-index: 101;
			}

			.tooltip-header {
				font-size: 0.75rem;
				font-weight: 800;
				text-transform: uppercase;
				margin-bottom: 6px;
				color: var(--color-accent);
				border-bottom: 2px solid var(--color-accent);
				padding-bottom: 4px;
				letter-spacing: 0.05em;
			}
			.tooltip-expiry {
				font-size: 0.7rem;
				color: var(--color-accent);
				margin-bottom: 6px;
				opacity: 0.9;
			}
			.tooltip-terms {
				margin: 0;
				padding-left: 14px;
				font-size: 0.7rem;
				color: var(--color-accent);
				opacity: 0.95;
				line-height: 1.4;
			}
			.tooltip-terms li {
				margin-bottom: 4px;
			}

			/* Copy Success Tooltip */
			.copy-success-tooltip {
				position: absolute;
				bottom: calc(100% + 8px);
				left: 50%;
				transform: translateX(-50%) translateY(5px);
				background: var(--color-accent);
				color: #ffffff;
				padding: 6px 10px;
				border-radius: 6px;
				font-size: 0.75rem;
				font-weight: 800;
				white-space: nowrap;
				opacity: 0;
				visibility: hidden;
				transition: all 0.15s cubic-bezier(0.175, 0.885, 0.32, 1.275);
				pointer-events: none;
				border: 2px solid var(--color-accent);
				box-shadow: 2px 2px 0px rgba(0,0,0,0.25);
			}
			.copy-success-tooltip::after {
				content: '';
				position: absolute;
				top: 100%;
				left: 50%;
				transform: translateX(-50%);
				border-width: 4px;
				border-style: solid;
				border-color: var(--color-accent) transparent transparent transparent;
			}
			.coupon-copy-btn.copied .copy-success-tooltip {
				opacity: 1;
				visibility: visible;
				transform: translateX(-50%) translateY(0);
			}

			/* Empty State Styling */
			.coupon-empty-state {
				display: flex;
				flex-direction: column;
				align-items: center;
				text-align: center;
				padding: 16px 8px 8px 8px;
			}
			.coupon-empty-state .empty-icon {
				color: var(--color-accent);
				opacity: 0.35;
				margin-bottom: 12px;
				display: flex;
				align-items: center;
				justify-content: center;
				transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
			}
			.coupon-empty-state:hover .empty-icon {
				transform: scale(1.1) rotate(-8deg);
				opacity: 0.6;
			}
			.coupon-empty-state .empty-title {
				font-size: 0.95rem;
				font-weight: 800;
				color: var(--color-accent);
				margin: 0 0 6px 0;
			}
			.coupon-empty-state .empty-desc {
				font-size: 0.78rem;
				line-height: 1.4;
				color: var(--color-accent);
				opacity: 0.65;
				margin: 0;
			}

			
			/* META LIST */
			.meta-list {
				display: flex;
				flex-direction: column;
				gap: 12px;
			}
			.meta-row {
				display: flex;
				justify-content: space-between;
				gap: 12px;
				font-size: 0.85rem;
				line-height: 1.4;
				border-bottom: 1px dotted rgba(10, 37, 64, 0.1);
				padding-bottom: 8px;
			}
			.meta-row:last-child {
				border-bottom: none;
				padding-bottom: 0;
			}
			.meta-key {
				font-weight: 700;
				opacity: 0.7;
			}
			.meta-val {
				font-weight: 800;
				text-align: right;
			}
			.meta-val a {
				text-decoration: underline;
			}

			/* PLATFORMS */
			.platform-chips {
				display: flex;
				flex-wrap: wrap;
				gap: 8px;
			}
			.platform-chip {
				padding: 6px 12px;
				border-radius: 10px;
				background: #FAF2EA;
				border: 2px solid var(--color-accent);
				font-size: 0.8rem;
				font-weight: 700;
				display: flex;
				align-items: center;
				gap: 6px;
				box-shadow: 2px 2px 0px var(--color-accent);
			}

			/* RATINGS */
			.rating-summary {
				display: flex;
				align-items: center;
				gap: 16px;
				margin-bottom: 16px;
			}
			.rating-num {
				font-size: 2.8rem;
				font-weight: 800;
				line-height: 1;
				font-family: var(--font-body);
			}
			.rating-stars {
				display: flex;
				gap: 2px;
				color: #FACC15;
				font-size: 1.1rem;
			}
			.rating-count {
				font-size: 0.75rem;
				opacity: 0.7;
				margin-top: 4px;
				font-weight: 600;
			}
			.rating-bars {
				display: flex;
				flex-direction: column;
				gap: 8px;
			}
			.rating-bar-row {
				display: flex;
				align-items: center;
				gap: 10px;
				font-size: 0.75rem;
				font-weight: 700;
			}
			.rating-bar-label {
				width: 8px;
				text-align: center;
			}
			.rating-bar-track {
				flex: 1;
				height: 8px;
				background: #FAF2EA;
				border: 2px solid var(--color-accent);
				border-radius: 10px;
				overflow: hidden;
			}
			.rating-bar-fill {
				height: 100%;
				background: #FACC15;
				border-right: 2px solid var(--color-accent);
			}
			.rating-bar-count {
				width: 24px;
				text-align: right;
				opacity: 0.7;
			}
			
			.btn-review {
				width: 100%;
				padding: 10px;
				margin-top: 16px;
				background: #ffffff;
				border: 2px solid var(--color-accent);
				border-radius: 12px;
				font-weight: 800;
				font-size: 0.85rem;
				cursor: pointer;
				box-shadow: 2px 2px 0px var(--color-accent);
				transition: all 0.15s;
			}
			.btn-review:hover {
				background: #FAF2EA;
				transform: translate(-1px, -1px);
				box-shadow: 3px 3px 0px var(--color-accent);
			}

			/* RELATED TOOLS */
			.related-list {
				display: flex;
				flex-direction: column;
				gap: 12px;
			}
			.related-item {
				background: #FAF2EA;
				border: 2px solid var(--color-accent);
				border-radius: 14px;
				padding: 12px;
				display: flex;
				align-items: center;
				justify-content: space-between;
				box-shadow: 3px 3px 0px var(--color-accent);
				transition: all 0.15s;
			}
			.related-item:hover {
				transform: translate(-2px, -2px);
				box-shadow: 5px 5px 0px var(--color-accent);
			}
			.related-left {
				display: flex;
				align-items: center;
				gap: 12px;
			}
			.related-logo {
				width: 40px;
				height: 40px;
				border-radius: 8px;
				border: 2px solid var(--color-accent);
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 1.25rem;
				font-weight: bold;
				background: #ffffff;
			}
			.related-logo :global(svg) {
				width: 22px;
				height: 22px;
			}
			.related-details {
				display: flex;
				flex-direction: column;
			}
			.related-name {
				font-weight: 800;
				font-size: 0.95rem;
				line-height: 1.2;
			}
			.related-meta {
				font-size: 0.75rem;
				opacity: 0.7;
				margin-top: 2px;
				font-weight: 600;
			}
			.related-arrow {
				font-weight: 800;
				font-size: 1.2rem;
				opacity: 0.7;
			}

			/* ─── RESPONSIVE ─────────────────────────────── */
			@media (max-width: 960px) {
				.detail-container {
					grid-template-columns: 1fr;
					gap: 32px;
				}
				.quick-stats {
					grid-template-columns: 1fr 1fr;
				}
			}
			@media (max-width: 640px) {
				.hero-top {
					flex-direction: column;
					align-items: flex-start;
					gap: 16px;
				}
				.hero-actions {
					width: 100%;
					justify-content: flex-start;
				}
				.btn-primary {
					flex-grow: 1;
					justify-content: center;
				}
				.features-grid {
					grid-template-columns: 1fr;
				}
				.pricing-grid {
					grid-template-columns: 1fr;
				}
				.quick-stats {
					grid-template-columns: 1fr 1fr;
				}
			}

			/* ─── REVIEWS SECTION ───────────────────────── */
			.reviews-container {
				display: flex;
				flex-direction: column;
				gap: 24px;
			}
			.reviews-list {
				display: flex;
				flex-direction: column;
				gap: 16px;
				margin-bottom: 12px;
			}
			.review-card {
				background: #ffffff;
				border: 2px solid var(--color-accent);
				border-radius: 16px;
				box-shadow: 4px 4px 0px var(--color-accent);
				padding: 20px;
				display: flex;
				flex-direction: column;
				gap: 10px;
				transition: transform 0.15s ease;
			}
			.review-card:hover {
				transform: translate(-1px, -1px);
				box-shadow: 5px 5px 0px var(--color-accent);
			}
			.review-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				flex-wrap: wrap;
				gap: 8px;
			}
			.review-user {
				font-weight: 800;
				font-size: 1.05rem;
			}
			.review-date {
				font-size: 0.8rem;
				opacity: 0.6;
				font-weight: 600;
			}
			.review-comment {
				font-size: 0.95rem;
				line-height: 1.5;
				margin: 0;
			}
			.review-stars {
				color: #FACC15;
				font-size: 1rem;
				display: flex;
				gap: 2px;
			}

			/* REVIEW FORM */
			.review-form-card {
				background: #FAF2EA;
				border: 2px solid var(--color-accent);
				border-radius: 20px;
				box-shadow: 4px 4px 0px var(--color-accent);
				padding: 24px;
				margin-top: 12px;
			}
			.form-title {
				font-size: 1.3rem;
				font-weight: 800;
				margin-bottom: 16px;
				display: flex;
				align-items: center;
				gap: 8px;
			}
			.form-group {
				display: flex;
				flex-direction: column;
				gap: 6px;
				margin-bottom: 16px;
			}
			.form-label {
				font-size: 0.85rem;
				font-weight: 800;
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}
			.form-input {
				background: #ffffff;
				border: 2px solid var(--color-accent);
				border-radius: 10px;
				padding: 10px 14px;
				font-size: 0.95rem;
				font-family: inherit;
				box-shadow: 2px 2px 0px var(--color-accent);
				outline: none;
				transition: all 0.1s ease;
			}
			.form-input:focus {
				box-shadow: 4px 4px 0px var(--color-accent);
				transform: translate(-1px, -1px);
			}
			.form-textarea {
				min-height: 100px;
				resize: vertical;
			}
			
			/* STAR INPUT */
			.star-input-container {
				display: flex;
				gap: 6px;
				font-size: 1.8rem;
				color: #D1D5DB;
				cursor: pointer;
				user-select: none;
				margin-bottom: 4px;
			}
			.star-input-btn {
				transition: transform 0.1s ease, color 0.1s ease;
			}
			.star-input-btn:hover {
				transform: scale(1.15);
			}
			.star-input-btn.active {
				color: #FACC15;
			}

			/* STATUS MESSAGES */
			.review-status {
				padding: 12px 16px;
				border-radius: 10px;
				border: 2px solid var(--color-accent);
				font-size: 0.9rem;
				font-weight: 700;
				margin-top: 12px;
				display: none;
			}
			.review-status.success {
				background: #D1FAE5;
				color: #065F46;
				box-shadow: 2px 2px 0px var(--color-accent);
			}
			.review-status.error {
				background: #FEE2E2;
				color: #991B1B;
				box-shadow: 2px 2px 0px var(--color-accent);
			}
			.review-status.loading {
				background: #FEF3C7;
				color: #92400E;
				box-shadow: 2px 2px 0px var(--color-accent);
			}
			
			.empty-reviews {
				text-align: center;
				padding: 30px 20px;
				background: #FAF2EA;
				border: 2px dashed var(--color-accent);
				border-radius: 16px;
				font-weight: 700;
				color: var(--color-accent);
				opacity: 0.8;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<!-- BREADCRUMB -->
			<div class="breadcrumb">

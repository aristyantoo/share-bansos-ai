		<!-- JS FOR SWITCHER AND SLIDER -->
		<script>
			// Pricing plans Switcher & Slider controller
			document.addEventListener('DOMContentLoaded', () => {
				const section = document.querySelector('[data-plans-monthly]');
				if (!section) return;

				const monthlyPlans = JSON.parse(section.getAttribute('data-plans-monthly') || '[]');
				const annualPlans = JSON.parse(section.getAttribute('data-plans-annual') || '[]');
				
				let currentType = 'monthly'; // 'monthly' or 'annual'
				let currentIndex = 1; // Default selected index for slider (usually Pro/1)

				const tabs = document.querySelectorAll('.pricing-tab');
				const sliderInput = document.getElementById('pricing-slider-input') as HTMLInputElement;
				const sliderLabels = document.querySelectorAll('.neo-slider-label');

				// DOM Elements for slider card
				const badge = document.getElementById('slider-popular-badge');
				const planName = document.getElementById('slider-plan-name');
				const taglineId = document.getElementById('slider-plan-tagline-id');
				const taglineEn = document.getElementById('slider-plan-tagline-en');
				const priceAmount = document.getElementById('slider-price-amount');
				const periodId = document.getElementById('slider-price-period-id');
				const periodEn = document.getElementById('slider-price-period-en');
				const noteId = document.getElementById('slider-price-note-id');
				const noteEn = document.getElementById('slider-price-note-en');
				const ctaTextId = document.getElementById('slider-cta-text-id');
				const ctaTextEn = document.getElementById('slider-cta-text-en');
				const ctaButton = document.getElementById('slider-plan-cta');
				const featuresList = document.getElementById('slider-features-list');

				function updateSliderCard() {
					if (!sliderInput) return;
					const plans = currentType === 'monthly' ? monthlyPlans : annualPlans;
					const plan = plans[currentIndex];

					if (!plan) return;

					// Update popular badge
					if (plan.popular) {
						badge.style.display = 'block';
						badge.textContent = document.documentElement.lang === 'en' ? 'Popular' : 'Populer';
						ctaButton.className = 'plan-cta cta-accent';
					} else {
						badge.style.display = 'none';
						ctaButton.className = 'plan-cta cta-outline';
					}

					// Update static info
					if (plan.name === 'Free') {
						planName.innerHTML = '<span class="lang-id">Gratis</span><span class="lang-en">Free</span>';
					} else {
						planName.textContent = plan.name;
					}
					taglineId.textContent = plan.tagline;
					taglineEn.textContent = plan.taglineEn;
					priceAmount.textContent = plan.price;
					periodId.textContent = plan.period;
					periodEn.textContent = plan.periodEn;
					noteId.textContent = plan.annualNote;
					noteEn.textContent = plan.annualNoteEn;
					ctaTextId.textContent = plan.ctaText;
					ctaTextEn.textContent = plan.ctaTextEn;

					// Rebuild features list
					featuresList.innerHTML = '';
					plan.features.forEach((featureText, idx) => {
						const fDiv = document.createElement('div');
						fDiv.className = 'plan-feature';
						fDiv.innerHTML = `
							<span class="check">✓</span>
							<span class="lang-id">${featureText}</span>
							<span class="lang-en">${plan.featuresEn[idx]}</span>
						`;
						featuresList.appendChild(fDiv);
					});

					// Update label active class
					sliderLabels.forEach((lbl, idx) => {
						if (idx === currentIndex) {
							lbl.classList.add('active');
						} else {
							lbl.classList.remove('active');
						}
					});
				}

				// Tab Toggling (Monthly / Annual)
				tabs.forEach(tab => {
					tab.addEventListener('click', () => {
						tabs.forEach(t => t.classList.remove('active'));
						tab.classList.add('active');
						
						const type = tab.getAttribute('data-pricing-type');
						currentType = type;

						// If standard grids exist, toggle them
						const monthlyGrid = document.getElementById('pane-monthly-grid');
						const annualGrid = document.getElementById('pane-annual-grid');

						if (monthlyGrid && annualGrid) {
							if (type === 'monthly') {
								monthlyGrid.classList.add('active');
								annualGrid.classList.remove('active');
							} else {
								monthlyGrid.classList.remove('active');
								annualGrid.classList.add('active');
							}
						} else {
							// Update the slider card
							updateSliderCard();
						}
					});
				});

				// Slider Range Input Listener
				if (sliderInput) {
					sliderInput.addEventListener('input', (e) => {
						currentIndex = parseInt((e.target as HTMLInputElement).value);
						updateSliderCard();
					});

					// Slider label clicking
					sliderLabels.forEach(label => {
						label.addEventListener('click', () => {
							const idx = parseInt(label.getAttribute('data-index') || '0');
							currentIndex = idx;
							sliderInput.value = idx.toString();
							updateSliderCard();
						});
					});

					// Initial load for slider card
					updateSliderCard();
				}
			});
		</script>

		<!-- JS FOR SUPABASE REVIEWS -->
		<script>
			import { createClient } from '@supabase/supabase-js';

			document.addEventListener('DOMContentLoaded', () => {
				const container = document.getElementById('reviews-container');
				if (!container) return;

				const supabaseUrl = container.getAttribute('data-supabase-url');
				const supabaseKey = container.getAttribute('data-supabase-key');
				const toolSlug = container.getAttribute('data-tool-slug');

				if (!supabaseUrl || !supabaseKey || !toolSlug) {
					console.error('Supabase configuration missing');
					return;
				}

				const supabase = createClient(supabaseUrl, supabaseKey);

				const reviewsList = document.getElementById('reviews-list');
				const reviewForm = document.getElementById('review-form') as HTMLFormElement;
				const formStatus = document.getElementById('form-status');
				const starRatingInput = document.getElementById('star-rating-input');
				const selectedRatingInput = document.getElementById('selected-rating') as HTMLInputElement;
				
				// Sidebar Rating DOM Elements
				const sidebarRatingNum = document.querySelector('.rating-num');
				const sidebarRatingCount = document.querySelector('.rating-count');
				const sidebarRatingStars = document.querySelector('.rating-summary .rating-stars');
				const sidebarRatingBars = document.querySelectorAll('.rating-bar-row');
				const sidebarWriteBtn = document.getElementById('sidebar-write-review-btn');

				// Scroll to write review form smoothly
				if (sidebarWriteBtn) {
					sidebarWriteBtn.addEventListener('click', (e) => {
						e.preventDefault();
						const formSection = document.getElementById('write-review-section');
						if (formSection) {
							formSection.scrollIntoView({ behavior: 'smooth', block: 'center' });
							// Highlight name input
							const nameInput = document.getElementById('review-name');
							if (nameInput) nameInput.focus();
						}
					});
				}

				// Interactive Star Rating Form Input
				if (starRatingInput) {
					const stars = starRatingInput.querySelectorAll('.star-input-btn');
					
					function highlightStars(ratingValue: number) {
						stars.forEach(star => {
							const val = parseInt(star.getAttribute('data-value') || '0');
							if (val <= ratingValue) {
								star.classList.add('active');
							} else {
								star.classList.remove('active');
							}
						});
					}

					// Initial highlight (default value = 5)
					highlightStars(parseInt(selectedRatingInput.value));

					stars.forEach(star => {
						star.addEventListener('click', () => {
							const val = parseInt(star.getAttribute('data-value') || '5');
							selectedRatingInput.value = val.toString();
							highlightStars(val);
						});
					});
				}

				// Helper to format date
				function formatDate(dateString: string) {
					const date = new Date(dateString);
					const lang = document.documentElement.lang || 'id';
					if (lang === 'id') {
						return date.toLocaleDateString('id-ID', {
							year: 'numeric',
							month: 'long',
							day: 'numeric'
						});
					} else {
						return date.toLocaleDateString('en-US', {
							year: 'numeric',
							month: 'long',
							day: 'numeric'
						});
					}
				}

				// Fetch and render reviews
				async function fetchReviews() {
					try {
						// Fetch reviews from Supabase
						const { data, error } = await supabase
							.from('reviews')
							.select('*')
							.eq('tool_slug', toolSlug)
							.eq('is_approved', true)
							.order('created_at', { ascending: false });

						if (error) throw error;

						renderReviews(data || []);
						updateSidebarRating(data || []);
					} catch (err: any) {
						console.error('Failed to fetch reviews:', err);
						reviewsList.innerHTML = `
							<div class="review-status error" style="display: block;">
								<span class="lang-id">Gagal memuat ulasan: ${err.message}</span>
								<span class="lang-en">Failed to load reviews: ${err.message}</span>
							</div>
						`;
					}
				}

				// Render review cards into DOM
				function renderReviews(reviews: any[]) {
					if (reviews.length === 0) {
						reviewsList.innerHTML = `
							<div class="empty-reviews">
								<span class="lang-id">Belum ada ulasan untuk alat ini. Jadilah yang pertama memberikan ulasan!</span>
								<span class="lang-en">No reviews for this tool yet. Be the first to write a review!</span>
							</div>
						`;
						return;
					}

					reviewsList.innerHTML = '';
					reviews.forEach(review => {
						const card = document.createElement('div');
						card.className = 'review-card';

						const starsHtml = '★'.repeat(review.rating) + '☆'.repeat(5 - review.rating);

						card.innerHTML = `
							<div class="review-header">
								<span class="review-user">${escapeHTML(review.name)}</span>
								<span class="review-date">${formatDate(review.created_at)}</span>
							</div>
							<div class="review-stars">${starsHtml}</div>
							<p class="review-comment">${escapeHTML(review.comment)}</p>
						`;
						reviewsList.appendChild(card);
					});
				}

				// Calculate and update ratings in Sidebar dynamically
				function updateSidebarRating(reviews: any[]) {
					if (!sidebarRatingNum || !sidebarRatingCount || !sidebarRatingStars) return;

					const totalReviews = reviews.length;
					if (totalReviews === 0) {
						sidebarRatingNum.textContent = '0.0';
						sidebarRatingCount.innerHTML = `
							<span class="lang-id">dari 0 ulasan</span>
							<span class="lang-en">from 0 reviews</span>
						`;
						sidebarRatingStars.innerHTML = '☆☆☆☆☆'.split('').map(star => `<span style="color:#D1D5DB">★</span>`).join('');
						
						// Reset bars
						if (sidebarRatingBars) {
							sidebarRatingBars.forEach(row => {
								const fill = row.querySelector('.rating-bar-fill') as HTMLElement;
								const pctText = row.querySelector('.rating-bar-count');
								if (fill) fill.style.width = '0%';
								if (pctText) pctText.textContent = '0%';
							});
						}
						return;
					}

					// Calculate average rating
					const sum = reviews.reduce((acc, curr) => acc + curr.rating, 0);
					const avg = (sum / totalReviews).toFixed(1);

					// Render dynamic average rating number
					sidebarRatingNum.textContent = avg;

					// Render dynamic review count text
					sidebarRatingCount.innerHTML = `
						<span class="lang-id">dari ${totalReviews} ulasan</span>
						<span class="lang-en">from ${totalReviews} reviews</span>
					`;

					// Render dynamic average stars
					const roundedAvg = Math.round(parseFloat(avg));
					let starsHtml = '';
					for (let i = 0; i < 5; i++) {
						if (i < roundedAvg) {
							starsHtml += '<span>★</span>';
						} else {
							starsHtml += '<span style="color:#D1D5DB">★</span>';
						}
					}
					sidebarRatingStars.innerHTML = starsHtml;

					// Calculate rating distribution for bars
					const distribution = { 5: 0, 4: 0, 3: 0, 2: 0, 1: 0 };
					reviews.forEach(review => {
						const r = review.rating as 1|2|3|4|5;
						if (distribution[r] !== undefined) {
							distribution[r]++;
						}
					});

					// Update each distribution bar
					if (sidebarRatingBars) {
						sidebarRatingBars.forEach(row => {
							const labelText = row.querySelector('.rating-bar-label')?.textContent;
							if (!labelText) return;

							const score = parseInt(labelText) as 1|2|3|4|5;
							const count = distribution[score] || 0;
							const pct = totalReviews > 0 ? Math.round((count / totalReviews) * 100) : 0;

							const fill = row.querySelector('.rating-bar-fill') as HTMLElement;
							const pctText = row.querySelector('.rating-bar-count');
							
							if (fill) fill.style.width = `${pct}%`;
							if (pctText) pctText.textContent = `${pct}%`;
						});
					}
				}

				// Escape HTML helpers to prevent XSS
				function escapeHTML(str: string) {
					return str.replace(/[&<>'"]/g, 
						tag => ({
							'&': '&amp;',
							'<': '&lt;',
							'>': '&gt;',
							"'": '&#39;',
							'"': '&quot;'
						}[tag] || tag)
					);
				}

				// Handle form submission
				if (reviewForm) {
					reviewForm.addEventListener('submit', async (e) => {
						e.preventDefault();

						// Clear previous status
						formStatus.style.display = 'none';
						formStatus.className = 'review-status';

						const nameInput = document.getElementById('review-name') as HTMLInputElement;
						const commentInput = document.getElementById('review-comment') as HTMLTextAreaElement;
						const ratingVal = parseInt(selectedRatingInput.value);

						const name = nameInput.value.trim();
						const comment = commentInput.value.trim();

						// Validate client side
						if (!name || !comment || isNaN(ratingVal) || ratingVal < 1 || ratingVal > 5) {
							showStatus(
								document.documentElement.lang === 'en' 
									? 'Please fill in all fields correctly.' 
									: 'Harap isi semua bidang dengan benar.',
								'error'
							);
							return;
						}

						// Show loading status
						showStatus(
							document.documentElement.lang === 'en'
								? 'Submitting your review...'
								: 'Mengirimkan ulasan Anda...',
							'loading'
						);

						// Disable form elements during submit
						toggleFormDisabled(true);

						try {
							const { error } = await supabase
								.from('reviews')
								.insert([
									{
										tool_slug: toolSlug,
										name: name,
										rating: ratingVal,
										comment: comment,
										is_approved: true
									}
								]);

							if (error) throw error;

							// Success
							showStatus(
								document.documentElement.lang === 'en'
									? 'Thank you! Your review has been submitted successfully.'
									: 'Terima kasih! Ulasan Anda berhasil dikirim.',
								'success'
							);

							// Reset form fields
							reviewForm.reset();
							// Reset rating stars to 5
							selectedRatingInput.value = '5';
							if (starRatingInput) {
								const stars = starRatingInput.querySelectorAll('.star-input-btn');
								stars.forEach(star => star.classList.add('active'));
							}

							// Refresh reviews list
							await fetchReviews();

						} catch (err: any) {
							console.error('Failed to submit review:', err);
							showStatus(
								document.documentElement.lang === 'en'
									? `Failed to submit review: ${err.message}`
									: `Gagal mengirimkan ulasan: ${err.message}`,
								'error'
							);
						} finally {
							toggleFormDisabled(false);
						}
					});
				}

				function showStatus(message: string, type: 'success' | 'error' | 'loading') {
					if (!formStatus) return;
					formStatus.innerHTML = message;
					formStatus.className = `review-status ${type}`;
					formStatus.style.display = 'block';
				}

				function toggleFormDisabled(disabled: boolean) {
					const inputs = reviewForm.querySelectorAll('input, textarea, button');
					inputs.forEach(el => {
						if (disabled) {
							el.setAttribute('disabled', 'disabled');
						} else {
							el.removeAttribute('disabled');
						}
					});
				}

				// Initial Fetch on load
				fetchReviews();
			});
		</script>

		<!-- JS FOR BOOKMARKS -->
		<script define:vars={{ toolId: tool.id }}>
			document.addEventListener('DOMContentLoaded', () => {
				const btnBookmark = document.querySelector('.btn-bookmark');
				if (!btnBookmark) return;

				// Load saved bookmarks from localStorage
				let bookmarks = [];
				try {
					bookmarks = JSON.parse(localStorage.getItem('bookmarks') || '[]');
				} catch (e) {
					console.error('Failed to parse bookmarks', e);
				}

				// Check if current tool is bookmarked
				if (bookmarks.includes(toolId)) {
					btnBookmark.classList.add('active');
				}

				// Premium Toast Function
				let toastTimeout;
				function showToast(message) {
					let toast = document.getElementById('neo-toast');
					if (!toast) {
						toast = document.createElement('div');
						toast.id = 'neo-toast';
						toast.style.cssText = `
							position: fixed;
							bottom: 30px;
							right: 30px;
							background: #ffffff;
							border: 2px solid var(--color-accent);
							box-shadow: 4px 4px 0px var(--color-accent);
							padding: 14px 24px;
							border-radius: 12px;
							font-family: var(--font-body);
							font-weight: 800;
							font-size: 0.95rem;
							color: var(--color-accent);
							z-index: 9999;
							transform: translateY(100px);
							opacity: 0;
							transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
							display: flex;
							align-items: center;
							gap: 10px;
							pointer-events: none;
						`;
						document.body.appendChild(toast);
					}

					toast.innerHTML = `
						<span style="font-size: 1.2rem;">✨</span>
						<span>${message}</span>
					`;

					// Show toast
					setTimeout(() => {
						toast.style.transform = 'translateY(0)';
						toast.style.opacity = '1';
					}, 50);

					// Hide toast after 3 seconds
					if (toastTimeout) clearTimeout(toastTimeout);
					toastTimeout = setTimeout(() => {
						toast.style.transform = 'translateY(100px)';
						toast.style.opacity = '0';
					}, 3000);
				}

				btnBookmark.addEventListener('click', () => {
					try {
						bookmarks = JSON.parse(localStorage.getItem('bookmarks') || '[]');
					} catch (e) {
						bookmarks = [];
					}

					const active = btnBookmark.classList.toggle('active');
					const index = bookmarks.indexOf(toolId);

					if (active) {
						if (index === -1) {
							bookmarks.push(toolId);
						}
					} else {
						if (index > -1) {
							bookmarks.splice(index, 1);
						}
					}

					localStorage.setItem('bookmarks', JSON.stringify(bookmarks));

					const isEn = document.documentElement.lang === 'en';
					const msg = active 
						? (isEn ? 'Tool saved to bookmarks!' : 'Alat disimpan ke bookmark!')
						: (isEn ? 'Tool removed from bookmarks!' : 'Alat dihapus dari bookmark!');
					showToast(msg);
				});

				// Coupon Copy Functionality
				const copyButtons = document.querySelectorAll('.coupon-copy-btn');
				copyButtons.forEach(btn => {
					btn.addEventListener('click', () => {
						const code = btn.getAttribute('data-code');
						if (!code) return;

						navigator.clipboard.writeText(code).then(() => {
							btn.classList.add('copied');
							const copyIcon = btn.querySelector('.copy-icon');
							const checkIcon = btn.querySelector('.check-icon');
							
							if (copyIcon) copyIcon.style.display = 'none';
							if (checkIcon) checkIcon.style.display = 'inline-block';

							// Also show the toast as a nice backup notification!
							const isEn = document.documentElement.lang === 'en';
							const msg = isEn ? `Copied: ${code}` : `Tersalin: ${code}`;
							showToast(msg);

							// Reset after 2 seconds
							setTimeout(() => {
								btn.classList.remove('copied');
								if (copyIcon) copyIcon.style.display = 'inline-block';
								if (checkIcon) checkIcon.style.display = 'none';
							}, 2000);
						}).catch(err => {
							console.error('Failed to copy text: ', err);
						});
					});
				});
			});
		</script>
	</body>
</html>


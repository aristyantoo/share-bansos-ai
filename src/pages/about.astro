---
import Layout from '../layouts/BlogPost.astro';
---

<Layout
	title="sysctl --read about"
	description="System metadata, specifications, and developer logs for Share Bansos AI."
>
	<div class="terminal-body">
		<div class="terminal-header">
			<span class="dot red"></span>
			<span class="dot yellow"></span>
			<span class="dot green"></span>
			<span class="terminal-title">
				<svg class="fish-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
					<path d="M0 0h512v512H0z" fill="none" />
					<path fill="#5A7B90" d="M250.951 125.662c27.423-29.128 49.085-36.773 69.001-37.803c33.145-1.721 42.21 16.069 40.628 40.458c-1.574 24.388-25.435 56.835-25.435 56.835" />

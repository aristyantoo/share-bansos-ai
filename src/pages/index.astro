---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import ToolLogo from '../components/ToolLogo.astro';

const tools = await getCollection('tools');
// Sort tools: featured first, then alphabetically by name
const sortedTools = tools.sort((a, b) => {
	if (a.data.featured && !b.data.featured) return -1;
	if (!a.data.featured && b.data.featured) return 1;
	return a.data.name.localeCompare(b.data.name);
});
---

<!doctype html>
<html lang="id">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				text-align: center;
				padding: 3.5rem 0 1rem 0;
				max-width: 800px;
				margin: 0 auto;
			}
			.hero h1 {
				margin-bottom: 1rem;
				line-height: 1.1;
			}
			.hero p {
				font-size: 1.4rem;
				opacity: 0.9;
				margin-bottom: 2rem;
			}
			.search-container {
				max-width: 500px;
				margin: 0 auto 2.5rem auto;
				position: relative;
			}
			.search-wrapper {
				position: relative;
				display: flex;
				align-items: center;
			}
			.search-icon {
				position: absolute;
				left: 20px;
				width: 20px;
				height: 20px;
				color: var(--color-accent);
				pointer-events: none;
			}
			#search-input {
				width: 100%;
				padding: 16px 20px 16px 52px;
				font-size: 1.1rem;
				font-family: var(--font-body);
				font-weight: 600;
				color: var(--color-accent);
				background: #ffffff;
				border: 2px solid var(--color-accent);
				border-radius: 9999px;
				box-shadow: 4px 4px 0px var(--color-accent);
				outline: none;
				transition: all 0.15s cubic-bezier(0.175, 0.885, 0.32, 1.275);
			}
			#search-input:focus {
				transform: translate(2px, 2px);
				box-shadow: 2px 2px 0px var(--color-accent);
			}
			.no-results-card {
				text-align: center;
				background: #ffffff;
				border: 2px dashed var(--color-accent);
				border-radius: 24px;
				padding: 40px;
				max-width: 500px;
				margin: 40px auto;
				box-shadow: 4px 4px 0px var(--color-accent);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1 data-i18n="hero.title">⚡ Explore the Best AI Tools ⚡</h1>
				<p data-i18n="hero.subtitle">
					A curated collection of the most powerful, beautiful, and advanced AI products to level up your workflow.
				</p>
				
				<div class="search-container">
					<div class="search-wrapper">
						<svg class="search-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="11" cy="11" r="8"></circle>
							<line x1="21" y1="21" x2="16.65" y2="16.65"></line>
						</svg>
						<input type="text" id="search-input" aria-label="Search AI Tools" data-i18n="search.placeholder" placeholder="Search AI Tools..." autocomplete="off" />
					</div>
				</div>
			</section>

			<div class="filter-sort-bar">
				<div class="filter-tabs">
					<button class="filter-tab active" data-filter="all" data-i18n="filter.all">Semua</button>
					<button class="filter-tab" data-filter="trend" data-i18n="filter.trend">Sedang Tren</button>
					<button class="filter-tab" data-filter="popular" data-i18n="filter.popular">Populer</button>
					<button class="filter-tab" data-filter="latest" data-i18n="filter.latest">Terbaru</button>
				</div>
				<div class="sort-wrapper">
					<label for="sort-select" class="sort-label" data-i18n="sort.label">Urutkan:</label>
					<select id="sort-select" class="sort-select">
						<option value="default" data-i18n="sort.default" selected>Bawaan</option>
						<option value="name-asc" data-i18n="sort.name_asc">Nama A-Z</option>
						<option value="name-desc" data-i18n="sort.name_desc">Nama Z-A</option>
						<option value="rating-desc" data-i18n="sort.rating_desc">Rating Tertinggi</option>
					</select>
				</div>
			</div>

			<section id="tools-section" class="tools-grid">
				{
					sortedTools.map((tool) => (
						<div class="tool-card"
							 data-name={tool.data.name}
							 data-category={tool.data.category}
							 data-featured={String(tool.data.featured ?? false)}
							 data-rating={tool.data.rating ?? 0}
							 data-rating-count={tool.data.ratingCount ?? 0}
							 data-launch-year={tool.data.launchYear ?? ""}
						>
							{tool.data.featured && <div class="featured-badge" data-i18n="tools.featured">Featured</div>}
							<div class="tool-card-content">
								<div class="tool-card-header">
									<div class="tool-logo-container" style={tool.data.accentColor ? `border-color: ${tool.data.accentColor}; background-color: ${tool.data.accentColor}10` : ''}>
										<ToolLogo name={tool.data.name} style={tool.data.accentColor ? `color: ${tool.data.accentColor}` : ''} />
									</div>
									<div class="tool-category-badge">{tool.data.category}</div>
								</div>
								<h2 class="tool-title">{tool.data.name}</h2>
								<div class="tool-creator"><span data-i18n="tools.creator">By</span> {tool.data.creator}</div>
								<p class="tool-description">
									<span class="lang-id">{tool.data.description}</span>
									<span class="lang-en">{tool.data.descriptionEn}</span>
								</p>
							</div>
							<hr class="tool-card-divider" />
							<div class="tool-card-footer">
								<div class="tool-value-label">
									<span class="tool-value-prefix" data-i18n="tools.value_prefix">Best for</span>
									<span class="tool-value-highlight">
										<span class="lang-id">{tool.data.value}</span>
										<span class="lang-en">{tool.data.valueEn}</span>
									</span>
								</div>
								<a href={`/tools/${tool.id}/`} class="tool-explore-btn" data-i18n="tools.explore">
									Explore →
								</a>
							</div>
						</div>
					))
				}
			</section>

			<div id="pagination-container" class="pagination-container">
				<button id="prev-page" class="pagination-btn prev-btn" data-i18n="pagination.prev">← Sebelumnya</button>
				<div id="page-numbers" class="page-numbers"></div>
				<button id="next-page" class="pagination-btn next-btn" data-i18n="pagination.next">Berikutnya →</button>
			</div>

			<div id="no-results" class="no-results-card" style="display: none;">
				<h2 data-i18n="search.noresults">No tools match your search 😔</h2>
				<p data-i18n="search.noresults_sub">Try searching for categories like "LLM", "Coding", or specific creators.</p>
			</div>
		</main>
		<Footer />

		<script>
			// Suggestions list for search placeholder rotation (bilingual)
			const suggestionsEn = [
				"Tools for coding...",
				"Tools for Image Generation...",
				"Tools for copywriting...",
				"Tools for video editing...",
				"Tools for UI design..."
			];

			const suggestionsId = [
				"Alat untuk pemrograman...",
				"Alat untuk membuat gambar...",
				"Alat untuk menulis artikel...",
				"Alat untuk edit video...",
				"Alat untuk desain UI..."
			];

			let currentSuggestionIndex = 0;
			let currentCharIndex = 0;
			let isDeleting = false;
			const input = document.getElementById('search-input') as HTMLInputElement | null;

			function type() {
				if (!input) return;
				const lang = document.documentElement.lang || 'id';
				const suggestions = lang === 'en' ? suggestionsEn : suggestionsId;
				const currentFullText = suggestions[currentSuggestionIndex % suggestions.length];
				
				if (isDeleting) {
					// Delete character
					input.placeholder = currentFullText.substring(0, currentCharIndex - 1);
					currentCharIndex--;
				} else {
					// Type character
					input.placeholder = currentFullText.substring(0, currentCharIndex + 1);
					currentCharIndex++;
				}
				
				let typeSpeed = 100;
				
				if (isDeleting) {
					typeSpeed /= 2; // Delete faster
				}
				
				if (!isDeleting && currentCharIndex === currentFullText.length) {
					// Wait before deleting
					typeSpeed = 2000;
					isDeleting = true;
				} else if (isDeleting && currentCharIndex === 0) {
					isDeleting = false;
					// Move to next suggestion
					currentSuggestionIndex = (currentSuggestionIndex + 1) % suggestions.length;
					typeSpeed = 500; // Pause before typing next suggestion
				}
				
				setTimeout(type, typeSpeed);
			}

			// Start typing animation
			if (input) {
				type();
			}

			// Search, Filter, Sort and Pagination State-driven logic
			const cards = Array.from(document.querySelectorAll('.tool-card')) as HTMLElement[];
			const defaultOrder = [...cards];
			const noResultsMessage = document.getElementById('no-results');
			const filterTabs = document.querySelectorAll('.filter-tab') as NodeListOf<HTMLButtonElement>;
			const sortSelect = document.getElementById('sort-select') as HTMLSelectElement | null;
			const prevPageBtn = document.getElementById('prev-page') as HTMLButtonElement | null;
			const nextPageBtn = document.getElementById('next-page') as HTMLButtonElement | null;
			const pageNumbersDiv = document.getElementById('page-numbers');
			const paginationContainer = document.getElementById('pagination-container');

			let searchQuery = '';
			let activeFilter = 'all';
			let activeSort = 'default';
			let currentPage = 1;
			const itemsPerPage = 12;

			function updateTools() {
				// 1. Filter by Search Query
				let filtered = cards.filter(card => {
					const name = card.dataset.name?.toLowerCase() || '';
					const category = card.dataset.category?.toLowerCase() || '';
					const description = card.querySelector('.tool-description')?.textContent?.toLowerCase() || '';
					const creator = card.querySelector('.tool-creator')?.textContent?.toLowerCase() || '';
					
					return name.includes(searchQuery) || 
						   category.includes(searchQuery) || 
						   description.includes(searchQuery) || 
						   creator.includes(searchQuery);
				});

				// 2. Filter by Active Filter Tab
				filtered = filtered.filter(card => {
					if (activeFilter === 'all') return true;
					if (activeFilter === 'trend') {
						const rating = parseFloat(card.dataset.rating || '0');
						const featured = card.dataset.featured === 'true';
						return featured || rating >= 4.7;
					}
					if (activeFilter === 'popular') {
						const ratingCount = parseInt(card.dataset.ratingCount || '0', 10);
						return ratingCount >= 800;
					}
					if (activeFilter === 'latest') {
						const launchYear = parseInt(card.dataset.launchYear || '0', 10);
						return launchYear >= 2024;
					}
					return true;
				});

				// 3. Sort the filtered list
				filtered.sort((a, b) => {
					if (activeSort === 'name-asc') {
						return (a.dataset.name || '').localeCompare(b.dataset.name || '');
					} else if (activeSort === 'name-desc') {
						return (b.dataset.name || '').localeCompare(a.dataset.name || '');
					} else if (activeSort === 'rating-desc') {
						const ratingA = parseFloat(a.dataset.rating || '0');
						const ratingB = parseFloat(b.dataset.rating || '0');
						if (ratingA !== ratingB) return ratingB - ratingA;
						
						const countA = parseInt(a.dataset.ratingCount || '0', 10);
						const countB = parseInt(b.dataset.ratingCount || '0', 10);
						return countB - countA;
					} else {
						// Default order
						return defaultOrder.indexOf(a) - defaultOrder.indexOf(b);
					}
				});

				// 4. Update DOM order
				const toolsSection = document.getElementById('tools-section');
				if (toolsSection) {
					filtered.forEach(card => {
						toolsSection.appendChild(card);
					});
				}

				// 5. Handle Pagination
				const totalItems = filtered.length;
				const totalPages = Math.ceil(totalItems / itemsPerPage) || 1;
				
				if (currentPage > totalPages) {
					currentPage = totalPages;
				}
				if (currentPage < 1) {
					currentPage = 1;
				}

				const startIndex = (currentPage - 1) * itemsPerPage;
				const endIndex = startIndex + itemsPerPage;

				cards.forEach(card => {
					card.style.display = 'none';
				});

				filtered.forEach((card, index) => {
					if (index >= startIndex && index < endIndex) {
						card.style.display = 'flex';
					}
				});

				// 6. Update UI for Results and Pagination Controls
				if (noResultsMessage) {
					noResultsMessage.style.display = totalItems === 0 ? 'block' : 'none';
				}
				if (paginationContainer) {
					paginationContainer.style.display = totalItems <= itemsPerPage ? 'none' : 'flex';
				}

				renderPaginationControls(totalPages);
			}

			function renderPaginationControls(totalPages: number) {
				if (prevPageBtn) {
					prevPageBtn.disabled = currentPage === 1;
				}
				if (nextPageBtn) {
					nextPageBtn.disabled = currentPage === totalPages;
				}

				if (pageNumbersDiv) {
					pageNumbersDiv.innerHTML = '';
					
					for (let i = 1; i <= totalPages; i++) {
						const btn = document.createElement('button');
						btn.className = `pagination-btn page-num ${i === currentPage ? 'active' : ''}`;
						btn.textContent = String(i);
						btn.addEventListener('click', () => {
							currentPage = i;
							updateTools();
							const toolsSection = document.getElementById('tools-section');
							if (toolsSection) {
								toolsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
							}
						});
						pageNumbersDiv.appendChild(btn);
					}
				}
			}

			// Event Listeners
			if (input) {
				input.addEventListener('input', (e) => {
					const target = e.target as HTMLInputElement;
					searchQuery = target.value.toLowerCase().trim();
					currentPage = 1; // Reset to page 1 on search
					updateTools();
				});
			}

			filterTabs.forEach(tab => {
				tab.addEventListener('click', () => {
					filterTabs.forEach(t => t.classList.remove('active'));
					tab.classList.add('active');
					activeFilter = tab.dataset.filter || 'all';
					currentPage = 1; // Reset to page 1 on filter change
					updateTools();
				});
			});

			if (sortSelect) {
				sortSelect.addEventListener('change', (e) => {
					const target = e.target as HTMLSelectElement;
					activeSort = target.value;
					currentPage = 1; // Reset to page 1 on sort change
					updateTools();
				});
			}

			if (prevPageBtn) {
				prevPageBtn.addEventListener('click', () => {
					if (currentPage > 1) {
						currentPage--;
						updateTools();
						const toolsSection = document.getElementById('tools-section');
						if (toolsSection) {
							toolsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
						}
					}
				});
			}

			if (nextPageBtn) {
				nextPageBtn.addEventListener('click', () => {
					// Get total pages dynamically
					const filtered = cards.filter(card => {
						const name = card.dataset.name?.toLowerCase() || '';
						const category = card.dataset.category?.toLowerCase() || '';
						const description = card.querySelector('.tool-description')?.textContent?.toLowerCase() || '';
						const creator = card.querySelector('.tool-creator')?.textContent?.toLowerCase() || '';
						
						const matchesSearch = name.includes(searchQuery) || 
											  category.includes(searchQuery) || 
											  description.includes(searchQuery) || 
											  creator.includes(searchQuery);
						if (!matchesSearch) return false;

						if (activeFilter === 'all') return true;
						if (activeFilter === 'trend') {
							const rating = parseFloat(card.dataset.rating || '0');
							const featured = card.dataset.featured === 'true';
							return featured || rating >= 4.7;
						}
						if (activeFilter === 'popular') {
							const ratingCount = parseInt(card.dataset.ratingCount || '0', 10);
							return ratingCount >= 800;
						}
						if (activeFilter === 'latest') {
							const launchYear = parseInt(card.dataset.launchYear || '0', 10);
							return launchYear >= 2024;
						}
						return true;
					});

					const totalPages = Math.ceil(filtered.length / itemsPerPage) || 1;
					if (currentPage < totalPages) {
						currentPage++;
						updateTools();
						const toolsSection = document.getElementById('tools-section');
						if (toolsSection) {
							toolsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
						}
					}
				});
			}

			// Initialize
			updateTools();
		</script>
	</body>
</html>
